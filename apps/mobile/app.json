{
  "expo": {
    "name": "EduPortal",
    "slug": "educontent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "eduportal",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eduportal.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to update your profile picture.",
        "NSPhotoLibraryUsageDescription": "Used to select a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "package": "com.eduportal.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4f46e5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://51c768ac-1770-4ed5-af6a-ff9f69a1bac6.preview.emergentagent.com",
      "eas": {
        "projectId": "03dce7fa-888b-4d00-8a34-a7003391ebe6"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "aiapptech2025s-organization"
  }
}
